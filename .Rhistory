# library(caret)
# library(data.table)
library(dplyr)
library(forcats) 
library(ggplot2)
library(plotrix)
library(stringr)
library(tidyr)
# library(tidymodels)
# library(tidyverse)
museums_df <- read.csv("./data/raw/museums.csv")
head(museums_df)
museum_type <- 
  ggplot(
    data = museums_df, 
    aes(
      x = fct_infreq(Museum.Type), 
      fill = Museum.Type, 
    )
  ) +
  geom_bar() + 
  geom_hline(yintercept = 0) + 
  labs(
    title = "Frequency of museum types", 
    x = "", 
    y = "", 
  ) +
  theme_minimal() + 
  theme(
    axis.text.x = element_text(angle = 90), 
    legend.position = "none", 
    panel.grid.minor = element_blank(), 
    panel.grid.major.x = element_blank(), 
    panel.grid.major.y = element_line(color = "grey80"), 
  ) +
  # 4.
  scale_x_discrete(
    labels = function(x) {
      x <- recode(
        x,
        "SCIENCE & TECHNOLOGY MUSEUM OR PLANETARIUM" = "SCIENCE AND TECHNOLOGY",
        "ZOO, AQUARIUM, OR WILDLIFE CONSERVATION" = "WILDLIFE CONSERVATION",
        "ARBORETUM, BOTANICAL GARDEN, OR NATURE CENTER" = "NATURE CENTER"
      )
      str_to_sentence(x)
    }
  ) +
  scale_y_continuous(labels = scales::comma)
museum_type
museum_class <-
  ggplot(
    data = museums_df, 
    aes(
      x = Is.Museum, 
      fill = Is.Museum, 
    ),
  ) +
  geom_bar() +
  geom_hline(yintercept = 0) + 
  labs(
    title = "Frequency of museums and nature centers",
    y = "", 
    x = "", 
  ) +
  scale_fill_discrete(
    name = "Type of museum", 
    labels = c("Museum", "Nature center"), 
  ) + 
  scale_x_discrete(
    labels = c(
      "TRUE" = "Museum", 
      "FALSE" = "Nature center"
    )
  ) + 
  scale_y_continuous(labels = scales::comma) + 
  theme_minimal() + 
  theme(
    legend.position = "none", 
    panel.grid.minor = element_blank(), 
    panel.grid.major.x = element_blank(), 
    panel.grid.major.y = element_line(color = "grey80"), 
  )
museum_class
# 6a. Filter data frame to select states.
museums_states <- museums_df %>%
 filter(
   State..Administrative.Location. == "LA" |
   State..Administrative.Location. == "CA" |
   State..Administrative.Location. == "NY" 
  ) %>%
  mutate(
    State..Administrative.Location. = factor(
      State..Administrative.Location., 
      levels = c( "NY", "CA", "LA")
    )
  )
# 6b. Create and print bar plot with facets.
museum_facet <- ggplot(
  data = museums_states, 
  aes(
    x = Is.Museum, 
    fill = Is.Museum, 
    )
  ) + 
  geom_bar() + 
  geom_hline(yintercept = 0) + 
  labs(
    title = "Frequency of museums vs. nature centers in California, New York, and Louisiana", 
    y = "", 
    x = "", 
  ) +
  scale_x_discrete(
    labels = c(
      "TRUE" = "Museum", 
      "FALSE" = "Nature center"
    )
  ) + 
  scale_fill_discrete(
    name = "", 
    labels = c("Museum", "Nature center"), 
  ) +
  facet_grid(cols = vars(State..Administrative.Location.)) + 
  scale_y_continuous(labels = scales::comma) + 
  theme_minimal() + 
  theme(
    legend.position = "none", 
    panel.grid.minor = element_blank(), 
    panel.grid.major.x = element_blank(), 
    panel.grid.major.y = element_line(color = "grey80"), 
  )
museum_facet
