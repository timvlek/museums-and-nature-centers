# Count number of museums per state
state_order <- museums_df %>%
  group_by(State..Administrative.Location.) %>%
  summarize(count = n()) %>%
  arrange(desc(count)) %>%
  pull(State..Administrative.Location.)
# Make State a factor in descending order
museums_df$State..Administrative.Location. <- factor(
  museums_df$State..Administrative.Location.,
  levels = state_order
)
# Now plot
ggplot(museums_df, aes(x = Is.Museum, fill = Is.Museum)) +
  geom_bar() +
  facet_grid(cols = vars(State..Administrative.Location.)) +
  scale_x_discrete(labels = c("TRUE" = "Museum", "FALSE" = "Nature Center")) +
  scale_y_continuous(labels = scales::comma) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 90, hjust = 1),
    legend.position = "none",
    panel.grid.minor = element_blank(),
    panel.grid.major.x = element_blank(),
    panel.grid.major.y = element_line(color = "grey80")
  )
