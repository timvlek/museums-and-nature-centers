museum_stacked <- ggplot(
  data = museums_df,
  aes(
    x = factor(Region.Code..AAM.), 
    fill = Is.Museum
      )
    ) + 
  
  # 9a.
  geom_bar(position="fill") +
  geom_hline(yintercept = 0) + 
  # 8a. 
  scale_x_discrete(
    labels = c(
      "1" = "New England", 
      "2" = "Mid-Atlantic", 
      "3" = "Southeastern", 
      "4" = "Midwest",
      "5" = "Mountain Plains",
      "6" = "Western"
      )
    ) + 
  # 8b. 
  scale_fill_discrete(labels = c("Museum", "Non-museum")) + 
  
  # 9b.
  scale_y_continuous(labels = scales::percent_format()) + 
  # 10.
  labs(
    title = "Regional frequencies of museum types", 
    x = "", 
    y = "",
    fill = "Type", 
    ) + 
  theme_minimal() + 
  theme(
    axis.text.x = element_text(
      angle = 90, 
      hjust = 1,
    ), 
    legend.position = "none", 
    panel.grid.minor = element_blank(), 
    panel.grid.major.x = element_blank(), 
    panel.grid.major.y = element_line(color = "grey80"), 
  )
museum_stacked
q()
